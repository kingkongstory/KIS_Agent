# KIS Open Trading API 설정
KIS_APPKEY=your_appkey_here
KIS_APPSECRET=your_appsecret_here
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_ENVIRONMENT=paper

# paper/passive 지정가 진입 체결 대기 timeout(ms). 2026-04-24 실측 52.9초 tail 대응 기본값.
KIS_ENTRY_FILL_TIMEOUT_MS=60000

# 장외 WebSocket 재연결 backoff (P0-1)
# 기본값은 false 이다. true 로 켜도 서버가 flat/free/no-position 상태라고
# 확인한 경우에만 장외 backoff 를 늘린다.
KIS_OFF_HOURS_SUPPRESSION_ENABLED=false
# 장외 재연결 최소 대기 시간(ms). 600000=10분, 900000=15분.
KIS_OFF_HOURS_WS_BACKOFF_MS=600000
# 09:00 정시 리셋은 정상 경로로 두고, 장 시작 전 인증/구독 warm-up 시작 시각만 조정한다.
KIS_PRE_OPEN_CONNECT_AT=08:30
KIS_REGULAR_OPEN_AT=09:00
KIS_REGULAR_CLOSE_AT=15:30
KIS_CLOSE_SETTLE_END_AT=15:45

# 서버 설정
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# 로깅 레벨
RUST_LOG=kis_agent=info,tower_http=info
